.env
.env.local
.env.*.local

# Build outputs
client/dist/
client/.vite/
server/dist/

# Logs
*.log
logs/
server/logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

