public/assets/**/*.jpeg
public/assets/**/*.png
public/assets/**/*.gif
public/assets/**/*.webp
public/assets/**/*.svg
public/assets/**/*.mp4
public/assets/**/*.mov
public/assets/**/*.pdf
# Keep gitkeep and README files
!public/assets/**/.gitkeep
!public/assets/**/README.md
